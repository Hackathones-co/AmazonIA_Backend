# SALA Galápagos — Environment Variables
# Copy this to .env and fill in your values

# API Keys (optional — app works without them with reduced features)
SALA_ANTHROPIC_API_KEY=        # Claude chatbot (text chat)

# ElevenLabs — real-time voice calls (Conversational AI)
SALA_ELEVENLABS_API_KEY=sk_50e1f951811a4c7823b64e25ed4af17a9623037278964c12       # from elevenlabs.io → Profile → SALA_ELEVENLABS_API_KEY=
SALA_ELEVENLABS_AGENT_ID=

# Google Weather
SALA_GOOGLE_WEATHER_API_KEY=      # from elevenlabs.io → Conversational AI → your agent

# Redis (optional — improves performance with caching)
SALA_REDIS_URL=                # e.g. redis://localhost:6379

# Server
SALA_LOG_LEVEL=INFO
